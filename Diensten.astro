---
// src/components/Samenwerken.astro
interface Props {
  lang?: 'nl' | 'en';
}
const { lang = 'nl' } = Astro.props;

const copy = {
  nl: {
    kicker: 'Hoe wil je samenwerken?',
    heading: { a: 'Kies jouw', b: 'weegschaal.' },
    paden: [
      {
        num: '01',
        name: 'Projectbasis',
        sub: 'Eenmalig · Vast budget · Helder resultaat',
        desc: 'Jij hebt een vraagstuk. Wij lossen het op, binnen afgesproken tijd en budget. Daarna ben je vrij.',
        cta: 'Vraag een offerte aan →',
        href: '#contact',
      },
      {
        num: '02',
        name: 'Abonnement',
        sub: 'Maandelijks · Schaalbaar · Altijd bereikbaar',
        desc: 'Wij worden onderdeel van jouw team. Vaste uren, directe prioriteit, altijd bereikbaar. Maandelijks opzegbaar.',
        cta: 'Plan een kennismaking →',
        href: '#contact',
      },
    ],
  },
  en: {
    kicker: 'How do you want to work together?',
    heading: { a: 'Choose your', b: 'scale.' },
    paden: [
      {
        num: '01',
        name: 'Project basis',
        sub: 'One-time · Fixed budget · Clear result',
        desc: 'You have a challenge. We solve it, within agreed time and budget. Then you are free.',
        cta: 'Request a quote →',
        href: '#contact',
      },
      {
        num: '02',
        name: 'Subscription',
        sub: 'Monthly · Scalable · Always available',
        desc: 'We become part of your team. Fixed hours, direct priority, always reachable. Cancel monthly.',
        cta: 'Book an intro call →',
        href: '#contact',
      },
    ],
  },
};
const t = copy[lang];
---

<section class="samenwerken section" id="samenwerken">
  <div class="container">
    <p class="t-kicker fade-in">{t.kicker}</p>
    <h2 class="t-h2 samenwerken-h2 fade-in">
      {t.heading.a} <em>{t.heading.b}</em>
    </h2>

    <div class="samenwerken-grid">
      {t.paden.map((pad) => (
        <div class="card samenwerken-card fade-in">
          <div class="pad-header">
            <span class="pad-num">{pad.num}</span>
            <!-- Weegschaal icoon -->
            <svg class="pad-icon" viewBox="0 0 80 80" fill="none" aria-hidden="true">
              <line x1="40" y1="8" x2="40" y2="72" stroke="#c9963a" stroke-width="1.5"/>
              <line x1="10" y1="20" x2="70" y2="20" stroke="#c9963a" stroke-width="1.2"/>
              <circle cx="10" cy="20" r="3" stroke="#c9963a" stroke-width="1"/>
              <circle cx="70" cy="20" r="3" stroke="#c9963a" stroke-width="1"/>
              <path d="M4 20 Q10 36 16 20" stroke="#c9963a" stroke-width="0.8" fill="none" opacity="0.6"/>
              <path d="M64 20 Q70 30 76 20" stroke="#c9963a" stroke-width="0.8" fill="none" opacity="0.6"/>
              <line x1="28" y1="72" x2="52" y2="72" stroke="#c9963a" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="pad-name">{pad.name}</h3>
          <p class="pad-sub">{pad.sub}</p>
          <div class="gold-line"></div>
          <p class="t-body pad-desc">{pad.desc}</p>
          <a href={pad.href} class="pad-cta">{pad.cta}</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.samenwerken {
  background: rgba(255,255,255,0.015);
  border-top: 1px solid var(--border);
}

.samenwerken-h2 { margin: 1rem 0 4rem; }

.samenwerken-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--border);
}

.samenwerken-card {
  padding: 3rem 2.8rem;
  background: var(--black);
  display: flex;
  flex-direction: column;
}

.pad-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 1.5rem;
}

.pad-num {
  font-family: var(--ff-mono);
  font-size: 0.44rem;
  letter-spacing: 0.3em;
  color: rgba(201,169,110,0.3);
}

.pad-icon {
  width: 52px;
  height: 52px;
  opacity: 0.5;
}

.pad-name {
  font-family: var(--ff-head);
  font-weight: 200;
  font-size: clamp(1.5rem, 3vw, 2.2rem);
  color: var(--white);
  margin-bottom: 0.4rem;
}

.pad-sub {
  font-family: var(--ff-mono);
  font-size: 0.48rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(201,169,110,0.35);
  margin-bottom: 0;
}

.pad-desc { margin: 0; flex: 1; }

.pad-cta {
  display: inline-flex;
  align-items: center;
  font-family: var(--ff-mono);
  font-size: 0.52rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: rgba(201,169,110,0.55);
  margin-top: 2rem;
  transition: color 0.2s;
}
.pad-cta:hover { color: var(--gold); }

@media (max-width: 768px) {
  .samenwerken-grid { grid-template-columns: 1fr; }
  .samenwerken-card { padding: 2.2rem 1.6rem; }
}
</style>
