/* ============================================
   MA'AT ANALYTICS — Design System
   Fraunces (koppen) · DM Sans (body) · DM Mono (labels)
   ============================================ */

@import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,200;0,9..144,700;1,9..144,200;1,9..144,700&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@300;400&display=swap');

/* ── Tokens ── */
:root {
  --black:    #100c07;
  --black-2:  #13100c;
  --white:    #f5edd8;
  --cream:    #f0ebe2;
  --gold:     #d4a853;
  --gold-lt:  #e8c070;
  --gold-dk:  #8a5820;
  --muted:    rgba(240,235,226,0.55);
  --border:   rgba(201,169,110,0.12);

  --ff-head:  'Fraunces', serif;
  --ff-body:  'DM Sans', sans-serif;
  --ff-mono:  'DM Mono', monospace;

  --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
  --ease-in:  cubic-bezier(0.55, 0, 1, 0.45);
}

/* ── Reset ── */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  background: var(--black);
  color: var(--white);
  font-family: var(--ff-body);
  font-weight: 300;
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
}

img, svg { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }
button { font-family: inherit; }

/* ── Typography ── */
.t-kicker {
  font-family: var(--ff-mono);
  font-size: 0.52rem;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--gold);
  opacity: 0.6;
}

.t-h1 {
  font-family: var(--ff-head);
  font-weight: 200;
  font-size: clamp(3rem, 7vw, 6.5rem);
  line-height: 1.0;
  letter-spacing: -0.02em;
}

.t-h2 {
  font-family: var(--ff-head);
  font-weight: 200;
  font-size: clamp(2rem, 4.5vw, 3.8rem);
  line-height: 1.05;
  letter-spacing: -0.01em;
}

.t-h3 {
  font-family: var(--ff-head);
  font-weight: 200;
  font-size: clamp(1.4rem, 3vw, 2.2rem);
  line-height: 1.2;
}

.t-body {
  font-size: clamp(0.9rem, 1.5vw, 1.05rem);
  color: var(--muted);
  line-height: 1.8;
}

em { font-style: italic; color: var(--gold); }

/* ── Layout ── */
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 4.5rem;
}

.section {
  padding: 8rem 0;
}

@media (max-width: 768px) {
  .container { padding: 0 1.4rem; }
  .section { padding: 5rem 0; }
}

/* ── Gold divider ── */
.gold-line {
  width: 32px;
  height: 1px;
  background: var(--gold);
  opacity: 0.4;
  margin: 1.4rem 0;
}

/* ── Buttons ── */
.btn-gold {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--ff-mono);
  font-size: 0.62rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--black);
  background: var(--gold);
  border: none;
  padding: 0.9rem 2.4rem;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.btn-gold:hover {
  background: var(--gold-lt);
  transform: translateY(-1px);
}

.btn-ghost {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--ff-mono);
  font-size: 0.62rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gold);
  background: transparent;
  border: 1px solid rgba(201,169,110,0.25);
  padding: 0.9rem 2.4rem;
  cursor: pointer;
  transition: border-color 0.2s, color 0.2s;
}
.btn-ghost:hover {
  border-color: var(--gold);
  color: var(--white);
}

/* ── Card ── */
.card {
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border);
  padding: 2.5rem;
  transition: border-color 0.3s, background 0.3s;
}
.card:hover {
  border-color: rgba(201,169,110,0.28);
  background: rgba(255,255,255,0.05);
}

/* ── Fade-in animation ── */
.fade-in {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s var(--ease-out), transform 0.6s var(--ease-out);
}
.fade-in.visible {
  opacity: 1;
  transform: translateY(0);
}
