---
// src/components/Werkwijze.astro
interface Props {
  lang?: 'nl' | 'en';
}
const { lang = 'nl' } = Astro.props;

const copy = {
  nl: {
    kicker: 'Hoe het werkt',
    heading: { a: 'Van chaos', b: 'naar inzicht.' },
    steps: [
      {
        num: '01',
        title: 'Wegen',
        desc: 'We luisteren eerst. Geen code voordat we het vraagstuk begrijpen.',
        detail: 'Intakegesprek · Probleemanalyse · Scope bepalen',
      },
      {
        num: '02',
        title: 'Bouwen',
        desc: 'We bouwen precies wat past. Geen standaardoplossingen, alleen maatwerk.',
        detail: 'Iteratief · Wekelijkse updates · Jij hebt altijd inzicht',
      },
      {
        num: '03',
        title: 'Overdragen',
        desc: 'Jij begrijpt alles wat gebouwd is. De kennis blijft bij jou, niet bij ons.',
        detail: 'Documentatie · Training · Geen lock-in',
      },
    ],
  },
  en: {
    kicker: 'How it works',
    heading: { a: 'From chaos', b: 'to insight.' },
    steps: [
      {
        num: '01',
        title: 'Weigh',
        desc: 'We listen first. No code before we understand the problem.',
        detail: 'Intake · Problem analysis · Scope definition',
      },
      {
        num: '02',
        title: 'Build',
        desc: 'We build exactly what fits. No standard solutions, only custom work.',
        detail: 'Iterative · Weekly updates · Full transparency',
      },
      {
        num: '03',
        title: 'Transfer',
        desc: 'You understand everything that was built. The knowledge stays with you.',
        detail: 'Documentation · Training · No lock-in',
      },
    ],
  },
};
const t = copy[lang];
---

<section class="werkwijze section" id="werkwijze">
  <div class="container">
    <p class="t-kicker fade-in">{t.kicker}</p>
    <h2 class="t-h2 werkwijze-h2 fade-in">
      {t.heading.a} <em>{t.heading.b}</em>
    </h2>

    <div class="werkwijze-steps">
      {t.steps.map((step, i) => (
        <div class="werkwijze-step fade-in">
          <div class="step-num">{step.num}</div>
          <div class="step-body">
            <h3 class="step-title">{step.title}</h3>
            <div class="gold-line"></div>
            <p class="t-body step-desc">{step.desc}</p>
            <p class="step-detail">{step.detail}</p>
          </div>
          {i < t.steps.length - 1 && (
            <div class="step-connector" aria-hidden="true">
              <svg width="1" height="80" viewBox="0 0 1 80">
                <line x1="0.5" y1="0" x2="0.5" y2="80"
                  stroke="rgba(212,168,83,0.2)"
                  stroke-width="1"
                  stroke-dasharray="4 4"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.werkwijze-h2 { margin: 1rem 0 5rem; }

.werkwijze-steps {
  display: flex;
  flex-direction: column;
  gap: 0;
  max-width: 680px;
}

.werkwijze-step {
  display: grid;
  grid-template-columns: 3.5rem 1fr;
  gap: 0 2rem;
  align-items: start;
}

.step-num {
  font-family: var(--ff-mono);
  font-size: 0.44rem;
  letter-spacing: 0.3em;
  color: rgba(201,169,110,0.3);
  padding-top: 0.2rem;
}

.step-title {
  font-family: var(--ff-head);
  font-weight: 200;
  font-size: clamp(1.4rem, 2.8vw, 2rem);
  color: var(--white);
  margin-bottom: 0;
}

.step-desc { margin: 0; }

.step-detail {
  font-family: var(--ff-mono);
  font-size: 0.46rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(201,169,110,0.3);
  margin-top: 0.8rem;
}

.step-connector {
  grid-column: 2;
  padding: 0.8rem 0;
  display: flex;
  align-items: center;
}

@media (max-width: 640px) {
  .werkwijze-steps { max-width: 100%; }
  .werkwijze-step { grid-template-columns: 2.5rem 1fr; }
}
</style>
